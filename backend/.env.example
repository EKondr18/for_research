# Скопируйте этот файл в .env для локального запуска (uvicorn main:app --reload
# читает переменные окружения из shell, .env нужен только вам для справки /
# если пользуетесь python-dotenv или `export $(cat .env | xargs)`).
# В Render эти переменные задаются в Dashboard -> Environment, .env туда не грузится.

GOOGLE_DRIVE_API_KEY=
# Необязательно, по умолчанию уже зашит ID папки проекта в config.py
GOOGLE_DRIVE_FOLDER_ID=1-0D0CBJouoD1npQ2VERpHnhdSol4S5Df

QDRANT_URL=
QDRANT_API_KEY=

# Токен Hugging Face (huggingface.co -> Settings -> Access Tokens, права
# Read достаточно). Нужен для расчёта эмбеддингов через HF Inference API --
# локальная ONNX-модель не влезает в 512MB free tier Render, поэтому
# эмбеддинги считаются удалённо на инфраструктуре HF.
HF_API_TOKEN=

GROQ_API_KEY=
# Необязательно, по умолчанию openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b

# Необязательный секрет для защиты POST /reindex. Если не задан — эндпоинт
# открыт для любого, кто знает URL backend'а.
REINDEX_TOKEN=

# Необязательно: список разрешённых origin для CORS через запятую.
# По умолчанию "*" (разрешены все) -- смените на домен Vercel в проде.
CORS_ALLOW_ORIGINS=*

# Необязательно, по умолчанию sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
